# 4EX Exchange Platform - Environment Configuration

# =============================================================================
# LICENSE CONFIGURATION
# =============================================================================

# License Key (Required for production)
# Format: LIC-XXXX-XXXX-XXXX-XXXX
# Obtain from https://4ex.com/licenses or via email after purchase
# VITE_LICENSE_KEY=

# License Server URL
# Default: https://licenses.4ex.com
# For self-hosted license server, update this URL
VITE_LICENSE_SERVER_URL=https://licenses.4ex.com

# License Public Key (Optional)
# Used for offline signature verification
# Contact support for your public key
# VITE_LICENSE_PUBLIC_KEY=

# License Validation Check Interval (hours)
# How often to revalidate license with server
# Default: 24 hours
# Minimum: 1 hour
VITE_LICENSE_CHECK_INTERVAL=24

# License Grace Period (days)
# Days allowed to operate when license server is unreachable
# Default: 7 days
# Range: 1-14 days
VITE_LICENSE_GRACE_PERIOD=7

# Enable License Validation
# Set to 'false' to disable license validation (development only)
# Default: true
# WARNING: Disabling validation in production violates license terms
VITE_LICENSE_ENABLE_VALIDATION=true

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application Environment
# Options: development, staging, production
VITE_APP_ENV=production

# Application Base URL
# Used for callbacks and redirects
VITE_APP_URL=https://exchange.example.com

# =============================================================================
# API CONFIGURATION
# =============================================================================

# CoinGecko API Configuration (for cryptocurrency rates)
# Default uses public API endpoint
VITE_COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Backend API URL (if using separate backend)
# VITE_API_BASE_URL=https://api.example.com

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable Debug Mode
# Shows additional logging and development tools
# Default: false (set to true only in development)
VITE_DEBUG=false

# Enable Analytics
# Set to true to enable usage analytics
VITE_ENABLE_ANALYTICS=true

# Enable Telegram Bot Integration
# Set to true if Telegram bot is configured
VITE_ENABLE_TELEGRAM=false

# Telegram Bot Token (if Telegram is enabled)
# Obtain from @BotFather on Telegram
# VITE_TELEGRAM_BOT_TOKEN=

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Session Timeout (minutes)
# How long user sessions remain active
VITE_SESSION_TIMEOUT=30

# Enable Two-Factor Authentication
# Set to true to require 2FA for admin access
VITE_ENABLE_2FA=true

# =============================================================================
# UI CONFIGURATION
# =============================================================================

# Default Theme
# Options: light, dark, system
VITE_DEFAULT_THEME=dark

# Default Language
# Options: en, ru
VITE_DEFAULT_LANGUAGE=ru

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================

# 1. License Configuration:
#    - Set VITE_LICENSE_KEY to your purchased license key
#    - Ensure VITE_LICENSE_SERVER_URL is accessible from your deployment
#    - Never commit license keys to version control
#
# 2. Production Deployment:
#    - Set VITE_LICENSE_ENABLE_VALIDATION=true
#    - Configure proper VITE_APP_URL for your domain
#    - Set VITE_DEBUG=false
#    - Enable HTTPS for license server communication
#
# 3. Development:
#    - Can set VITE_LICENSE_ENABLE_VALIDATION=false for local testing
#    - Mock license responses will be used in development mode
#    - Never deploy with validation disabled
#
# 4. Security:
#    - Rotate license keys if compromised
#    - Keep environment variables secure
#    - Use secrets management for sensitive values
#    - Enable 2FA for production deployments

# =============================================================================
# SUPPORT
# =============================================================================

# For license issues: licenses@4ex.com
# For technical support: support@4ex.com
# For sales inquiries: sales@4ex.com
# Documentation: https://docs.4ex.com
