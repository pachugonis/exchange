# ExchangeKit - Environment Configuration

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application Environment
# Options: development, staging, production
VITE_APP_ENV=production

# Application Base URL
# Used for callbacks and redirects
VITE_APP_URL=https://exchange.example.com

# =============================================================================
# API CONFIGURATION
# =============================================================================

# CoinGecko API Configuration (for cryptocurrency rates)
# Default uses public API endpoint
VITE_COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Blockchain payment tracking
# Опрос блокчейна выполняется на бэкенде (server/). Frontend обращается к нему
# по ${VITE_API_BASE_URL}/api/payments/check.
# BTC, LTC и TRON (TRX / USDT-TRC20) отслеживаются по публичным эксплорерам без ключа.
# Ключ Etherscan для сети Ethereum (ETH/ERC20) задаётся СЕРВЕРНОЙ переменной
# ETHERSCAN_API_KEY (см. ниже), а не VITE_-переменной.

# Backend API URL — base URL of the auth server (server/).
# Frontend calls ${VITE_API_BASE_URL}/api/auth/*
VITE_API_BASE_URL=http://localhost:4000

# =============================================================================
# AUTH SERVER CONFIGURATION (server/ — not exposed to the browser)
# =============================================================================

# Port the auth API listens on
AUTH_PORT=4000

# Allowed CORS origin (the frontend URL)
CORS_ORIGIN=http://localhost:5173

# PostgreSQL connection string
DATABASE_URL=postgres://localhost:5432/exchange

# JWT signing secret — MUST be a long random value in production.
# Generate with: openssl rand -hex 32
JWT_SECRET=
# Access token lifetime (e.g. 15m, 1h, 7d)
JWT_ACCESS_TTL=7d

# bcrypt cost factor (10-12 is typical)
BCRYPT_ROUNDS=12

# TOTP issuer label shown in authenticator apps
TOTP_ISSUER=ExchangeKit

# Seed admin account (created on first boot if no admin exists)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Administrator

# Brute-force protection
MAX_FAILED_LOGINS=5
LOCK_MINUTES=15

# Blockchain payment tracking — ключ Etherscan для отслеживания оплаты в сети
# Ethereum (ETH/ERC20). Без него BTC/LTC/TRON отслеживаются, а ETH-заявки
# подтверждаются оператором вручную.
ETHERSCAN_API_KEY=

# AML-проверка входящих транзакций через AMLBot (https://amlbot.com).
# Получите accessId/accessKey в личном кабинете AMLBot (раздел API).
# Если оставить пустыми — AML-скоринг отключён, заявки проходят без проверки.
AMLBOT_ACCESS_ID=
AMLBOT_ACCESS_KEY=
# Эндпоинт API (по умолчанию — официальный хост AMLBot, менять не нужно)
AMLBOT_BASE_URL=https://extrnlapiendpoint.silencatech.com
# Режим: fast — синхронный скоринг (рекомендуется), advanced — глубокий анализ
AMLBOT_FLOW=fast
AMLBOT_LOCALE=en
# Пороги риска в процентах (0–100): ≤ MEDIUM — низкий, ≤ HIGH — средний, > HIGH — высокий
AMLBOT_MEDIUM_THRESHOLD=20
AMLBOT_HIGH_THRESHOLD=79

# Public frontend URL — used to build links inside emails
APP_URL=http://localhost:5173

# SMTP — leave SMTP_HOST empty to log emails to the console instead of sending
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=ExchangeKit
SMTP_FROM_EMAIL=noreply@exchangekit.cc

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable Debug Mode
# Shows additional logging and development tools
# Default: false (set to true only in development)
VITE_DEBUG=false

# Enable Analytics
# Set to true to enable usage analytics
VITE_ENABLE_ANALYTICS=true

# Enable Telegram Bot Integration
# Set to true if Telegram bot is configured
VITE_ENABLE_TELEGRAM=false

# Telegram Bot Token (if Telegram is enabled)
# Obtain from @BotFather on Telegram
# VITE_TELEGRAM_BOT_TOKEN=

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Session Timeout (minutes)
# How long user sessions remain active
VITE_SESSION_TIMEOUT=30

# Enable Two-Factor Authentication
# Set to true to require 2FA for admin access
VITE_ENABLE_2FA=true

# =============================================================================
# UI CONFIGURATION
# =============================================================================

# Default Theme
# Options: light, dark, system
VITE_DEFAULT_THEME=dark

# Default Language
# Options: en, ru
VITE_DEFAULT_LANGUAGE=ru

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================

# 1. Production Deployment:
#    - Configure proper VITE_APP_URL for your domain
#    - Set VITE_DEBUG=false
#
# 2. Security:
#    - Keep environment variables secure
#    - Use secrets management for sensitive values
#    - Enable 2FA for production deployments

