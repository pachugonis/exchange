# License Server Configuration

# Server Port
LICENSE_SERVER_PORT=3001

# JWT Secret for Token Generation (CHANGE THIS IN PRODUCTION!)
# Generate a secure random string: openssl rand -base64 32
LICENSE_JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_IN_PRODUCTION

# Учётные данные для входа в веб-админку (http://<server>:PORT/admin)
# Логин (по умолчанию admin) и пароль. Пароль также используется как
# заголовок x-admin-password для curl/скриптов.
ADMIN_USERNAME=admin
# Use a strong password with letters, numbers, and special characters
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD_IN_PRODUCTION

# Каталог с артефактами релизов и манифестом releases.json.
# Сюда release.sh кладёт exchangekit-<version>.tar.gz и releases.json.
RELEASES_DIR=/opt/license-server/releases
